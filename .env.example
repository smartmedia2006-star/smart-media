# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/smartmedia_db?schema=public"

# ─────────────────────────────────────────────
# NEXT.JS
# ─────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ─────────────────────────────────────────────
# GOOGLE OAUTH (Admin Login)
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─────────────────────────────────────────────
# REDIS (BullMQ Job Queue)
# ─────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# ─────────────────────────────────────────────
# TWILIO (WhatsApp Business API)
# ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
# For production: whatsapp:+977XXXXXXXXXX (your approved number)

# ─────────────────────────────────────────────
# TELEGRAM BOT
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="your-telegram-bot-token-from-botfather"
TELEGRAM_BOT_USERNAME="SmartMediaNepalBot"

# ─────────────────────────────────────────────
# ZOHO MAIL (OAuth2)
# ─────────────────────────────────────────────
ZOHO_CLIENT_ID="your-zoho-client-id"
ZOHO_CLIENT_SECRET="your-zoho-client-secret"
ZOHO_REDIRECT_URI="http://localhost:3000/api/zoho/callback"
ZOHO_ACCOUNT_ID="your-zoho-account-id"
ZOHO_FROM_EMAIL="info@smartmedia.com.np"
ZOHO_FROM_NAME="Smart Media Nepal"
# After OAuth setup, these are stored in DB; seed them here for initial setup:
ZOHO_REFRESH_TOKEN="your-initial-refresh-token"

# ─────────────────────────────────────────────
# FILE STORAGE
# ─────────────────────────────────────────────
STORAGE_PROVIDER="local"  # "local" | "s3" | "cloudinary"
UPLOAD_DIR="./public/uploads"

# AWS S3 (if STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-south-1"
AWS_S3_BUCKET="smartmedia-assets"

# Cloudinary (if STORAGE_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─────────────────────────────────────────────
# SITE CONFIG
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://smartmedia.com.np"
NEXT_PUBLIC_SITE_NAME="Smart Media Nepal"
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_MAPS_API_KEY="your-google-maps-api-key"

# ─────────────────────────────────────────────
# ADMIN CONFIG
# ─────────────────────────────────────────────
ADMIN_EMAIL="admin@smartmedia.com.np"
ADMIN_NOTIFICATION_EMAIL="alerts@smartmedia.com.np"

# ─────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW="60000"
